# =========================

# SERVER CONFIG

# =========================

PORT=4000

# =========================

# DATABASE CONFIG

# =========================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=smart_agriculture

# =========================

# AUTH

# =========================

JWT_SECRET=your_secret_key

# =========================

# GEMINI AI

# =========================

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# =========================

# WEATHER API

# =========================

WEATHER_PROVIDER=openweather
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# =========================

# EMAIL (NODEMAILER)

# =========================

EMAIL_FROM="Smart Agriculture [no-reply@smartagri.local](mailto:no-reply@smartagri.local)"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=[your_email@gmail.com](mailto:your_email@gmail.com)
SMTP_PASS=your_app_password

# =========================

# OPTIONAL AI (DISEASE)

# =========================

AI_DISEASE_ENDPOINT=
AI_DISEASE_API_KEY=
AI_DISEASE_TIMEOUT_MS=8000
